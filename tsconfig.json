{
  // Ahoy! This be the TypeScript map fer our prime-number voyage.
  "compilerOptions": {
    // Arrr! Keep source in src and compiled loot in dist.
    "rootDir": "src",
    "outDir": "dist",

    // Avast! We sail with CommonJS on Node.js waters.
    "module": "commonjs",
    "target": "es2020",
    "types": ["node"],
    "lib": ["es2020"],

    // Shiver me timbers! Strict checks keep bugs off the deck.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Hoist the colors! Useful maps for debugging and tooling.
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Ye be warned: skip library checks to keep builds swift.
    "skipLibCheck": true
  },
  // Here be dragons: only compile the source cargo.
  "include": ["src/**/*"]
}
